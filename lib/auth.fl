// ============================================================================
// PART 7: 세션 통계
// ============================================================================

pub fn get_session_stats() -> map<string, i32>
  intent "현재 세션 통계 반환"
  do
    let stats = {}
    let active_count = 0
    let expired_count = 0
    let invalid_count = 0

    // TODO: 세션 맵 순회

    stats["active"] = active_count
    stats["expired"] = expired_count
    stats["invalid"] = invalid_count

    return stats
  end

pub fn cleanup_expired_sessions() -> i32
  intent "만료된 세션 정리"
  do
    let cleaned = 0
    let now = get_current_time()

    // TODO: 만료된 세션 삭제

    println("🗑️ " + int_to_string(cleaned) + "개의 만료된 세션 정리됨")
    return cleaned
  end
