        let config = {}
        config["site_name"] = "FreeLang Blog"
        config["site_url"] = "http://localhost:5021"
        config["max_post_size"] = "50000"
        config["cache_enabled"] = "true"
        config["rate_limit_enabled"] = "true"

        println("⚙️ 관리자: 설정 조회")
        return Ok(config)
      }
      Err(e) => return Err("권한 없음")
