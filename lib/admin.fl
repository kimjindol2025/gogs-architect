// ============================================================================
// PART 5: 시스템 통계 & 모니터링
// ============================================================================

pub fn get_system_stats(token: string) -> Result<SystemStats, string>
  intent "시스템 통계 조회"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        println("📊 관리자: 시스템 통계 조회")
        return Ok(GLOBAL_SYSTEM_STATS)
      }
      Err(e) => return Err("권한 없음")
    end
  end

pub fn get_system_health(token: string) -> Result<SystemHealth, string>
  intent "시스템 건강도 확인"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        // 시스템 상태 진단
        let health = SystemHealth {
          status: "healthy",
          cpu_percent: 35.5,
          memory_percent: 48.2,
          disk_percent: 65.3,
          database_ok: true,
          cache_ok: true,
          services_running: 5,
          last_check: get_current_time()
        }

        // 경고 조건 확인
        if health.cpu_percent > 80.0 || health.memory_percent > 85.0
          health.status = "warning"
        end

        if health.cpu_percent > 95.0 || !health.database_ok
          health.status = "critical"
        end

        println("🏥 관리자: 시스템 상태 " + health.status)
        return Ok(health)
      }
      Err(e) => return Err("권한 없음")
    end
  end

pub fn update_system_stats(total_posts: i32, total_users: i32, total_views: i32) -> void
  intent "시스템 통계 업데이트"
  do
    GLOBAL_SYSTEM_STATS.total_posts = total_posts
    GLOBAL_SYSTEM_STATS.total_users = total_users
    GLOBAL_SYSTEM_STATS.total_views = total_views
  end

// ============================================================================
// PART 6: 관리 로그
// ============================================================================

pub fn log_admin_action(token: string, action: string, target: string, status: string, details: string) -> void
  intent "관리자 작업 로깅"
  do
    let log = AdminLog {
      timestamp: get_current_time(),
      admin_id: 1,  // TODO: token에서 admin_id 추출
      action: action,
      target: target,
      status: status,
      details: details
    }

    GLOBAL_ADMIN_LOGS = array_append(GLOBAL_ADMIN_LOGS, log)
    println("📝 관리자 로그: " + action + " → " + target + " (" + status + ")")
  end

pub fn get_admin_logs(token: string, limit: i32) -> Result<array<AdminLog>, string>
  intent "최근 관리자 로그 조회"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        let result: array<AdminLog> = []
        let start = length(GLOBAL_ADMIN_LOGS) - limit
        if start < 0 start = 0 end

        for i = start; i < length(GLOBAL_ADMIN_LOGS); i++
          result = array_append(result, GLOBAL_ADMIN_LOGS[i])
        end

        println("📋 관리자: " + int_to_string(length(result)) + "개 로그 조회")
        return Ok(result)
      }
      Err(e) => return Err("권한 없음")
    end
  end

pub fn export_admin_logs(token: string) -> Result<string, string>
  intent "관리자 로그 CSV 내보내기"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        let csv = "timestamp,admin_id,action,target,status,details\n"

        for i = 0; i < length(GLOBAL_ADMIN_LOGS); i++
          let log = GLOBAL_ADMIN_LOGS[i]
          csv = csv + log.timestamp + "," + int_to_string(log.admin_id) + "," + log.action + "," + log.target + "," + log.status + ",\"" + log.details + "\"\n"
        end

        println("📥 관리자: 로그 내보내기 (" + int_to_string(length(GLOBAL_ADMIN_LOGS)) + " 행)")
        return Ok(csv)
      }
      Err(e) => return Err("권한 없음")
    end
  end

