pub fn admin_create_backup(token: string) -> Result<string, string>
  intent "전체 데이터 백업"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        let timestamp = get_current_time()
        let backup_file = "backup_" + replace_chars(timestamp, ":", "-") + ".json"

        println("💾 관리자: 백업 생성 → " + backup_file)
        log_admin_action(token, "create_backup", "", "성공", backup_file)

        return Ok(backup_file)
      }
      Err(e) => return Err("권한 없음")
    end
  end

pub fn admin_restore_backup(token: string, backup_file: string) -> Result<void, string>
  intent "백업 파일에서 복구"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        println("♻️ 관리자: 백업 복구 ← " + backup_file)
        log_admin_action(token, "restore_backup", backup_file, "성공", "")

        return Ok(void)
      }
      Err(e) => return Err("권한 없음")
    end
  end

pub fn admin_cleanup_database(token: string) -> Result<i32, string>
  intent "불필요한 데이터 정리"
  do
    match auth::has_permission(token, "admin")
      Ok(true) => {
        let cleaned = 0
        // TODO: 만료된 세션, 스팸 댓글 등 정리

        println("🧹 관리자: 데이터 정리 (" + int_to_string(cleaned) + " 항목)")
        log_admin_action(token, "cleanup_database", "", "성공", int_to_string(cleaned) + " 항목 정리")

        return Ok(cleaned)
      }
      Err(e) => return Err("권한 없음")
    end
  end

// ============================================================================
// PART 9: 내부 헬퍼 함수
// ============================================================================

fn validate_role(role: string) -> Result<bool, string>
  intent "역할이 유효한지 확인"
  do
    match role
      "admin" => return Ok(true)
      "editor" => return Ok(true)
      "viewer" => return Ok(true)
      _ => return Err("유효하지 않은 역할")
    end
  end

fn get_current_time() -> string
  intent "현재 시간"
  do
    return "2026-03-13T12:00:00Z"
  end

fn int_to_string(n: i32) -> string
  intent "정수를 문자열로"
  do
    return to_string(n)
  end

fn bool_to_string(b: bool) -> string
  intent "boolean을 문자열로"
  do
    return if b then "true" else "false" end
  end

fn length(s: string) -> i32
  intent "문자열 길이"
  do
    return string_length(s)
  end

fn replace_chars(s: string, old: string, new: string) -> string
  intent "문자 치환"
  do
    let result = ""
    for i = 0; i < length(s); i++
      let ch = substring(s, i, i + 1)
      result = result + if ch == old then new else ch end
    end
    return result
  end

fn substring(s: string, start: i32, end: i32) -> string
  intent "부분 문자열"
  do
    return string_slice(s, start, end)
  end

fn array_append(arr: array<AdminLog>, item: AdminLog) -> array<AdminLog>
  intent "배열에 추가"
  do
    return arr  // TODO: 실제 append 구현
  end
