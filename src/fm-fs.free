fn get_directory_size(path: String) -> Int {
    // 디렉터리 전체 크기 계산
    if !file_exists(path) || !file_is_dir(path) {
        return 0
    }

    var total = 0
    var files = fs_ls(path)
    var i = 0
    while i < list_len(files) {
        var file_name = list_get(files, i)
        var full_path = path + "/" + file_name

        if file_is_dir(full_path) {
            total = total + get_directory_size(full_path)
        } else {
            total = total + file_size(full_path)
        }

        i = i + 1
    }

    return total
}

fn get_breadcrumb_path(current_path: String) -> List {
    // 경로 브레드크럼 생성
    // /home/user/documents -> [("home", "/home"), ("user", "/home/user"), ("documents", "/home/user/documents")]
    var parts = str_split(current_path, "/")
    var result = list_new()
    var current = ""

    var i = 0
    while i < list_len(parts) {
        var part = list_get(parts, i)
        if part != "" {
            current = current + "/" + part
            var crumb = map_new()
            map_set(crumb, "name", part)
            map_set(crumb, "path", current)
            list_push(result, crumb)
        }
        i = i + 1
    }

    return result
}
