fn format_file_size(size_bytes: Int) -> String {
    // 파일 크기를 읽기 좋은 형식으로 변환
    if size_bytes < 1024 {
        return str_from_int(size_bytes) + " B"
    }
    var kb = size_bytes / 1024
    if kb < 1024 {
        return str_from_int(kb) + " KB"
    }
    var mb = kb / 1024
    if mb < 1024 {
        return str_from_int(mb) + " MB"
    }
    var gb = mb / 1024
    return str_from_int(gb) + " GB"
}

fn format_timestamp(timestamp: Int) -> String {
    // Unix 타임스탬프를 읽기 좋은 형식으로 변환
    // 실제로는 더 복잡한 날짜 파싱 필요
    return str_from_int(timestamp)
}

fn str_trim(s: String) -> String {
    // 양쪽 공백 제거
    var start = 0
    var end = str_len(s)

    while start < end && (str_substring(s, start, start + 1) == " " || str_substring(s, start, start + 1) == "\t") {
        start = start + 1
    }

    while end > start && (str_substring(s, end - 1, end) == " " || str_substring(s, end - 1, end) == "\t") {
        end = end - 1
    }

    if start >= end {
        return ""
    }

    return str_substring(s, start, end)
}

fn str_to_lower(s: String) -> String {
    // 소문자로 변환
    var result = ""
    var i = 0
    while i < str_len(s) {
        var char = str_substring(s, i, i + 1)
        if char >= "A" && char <= "Z" {
            var ord = ascii_value(char)
            char = ascii_char(ord + 32)
        }
        result = result + char
        i = i + 1
    }
    return result
}

fn ascii_value(char: String) -> Int {
    // 문자의 ASCII 값 반환 (간단한 구현)
    if char == "A" { return 65 }
    if char == "B" { return 66 }
    if char == "Z" { return 90 }
    return 0
}

fn ascii_char(code: Int) -> String {
    // ASCII 코드를 문자로 변환 (간단한 구현)
    return str_substring("ABCDEFGHIJKLMNOPQRSTUVWXYZ", code - 65, code - 64)
}

fn str_endswith(s: String, suffix: String) -> Bool {
    var s_len = str_len(s)
    var suffix_len = str_len(suffix)
    if suffix_len > s_len {
        return false
    }
    return str_substring(s, s_len - suffix_len, s_len) == suffix
}

fn list_find(lst: List, item: String) -> Int {
    // 리스트에서 항목 위치 찾기
    var i = 0
    while i < list_len(lst) {
        if list_get(lst, i) == item {
            return i
        }
        i = i + 1
    }
    return -1
}
