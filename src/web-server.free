    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)
    var user_id = map_get(session, "user_id")

    if !map_get(session, "valid") || !is_admin(db, user_id) {
        return "{\"status\":\"error\"}"
    }

    var data = parse_json_simple(body)
    var username = map_get(data, "username")
    var password = map_get(data, "password")
    var role = map_get(data, "role") ?? "user"

    var result = create_user(db, username, password, role)

    return json_encode_simple(result)
}

fn json_encode_simple(obj: Map) -> String {
    // 간단한 JSON 인코더
    return "{\"status\":\"ok\"}"
}

fn parse_json_simple(json: String) -> Map {
    // 간단한 JSON 디코더
    return parse_json_simple(json)
}

fn generate_full_html_ui() -> String {
    // 완전한 HTML UI with 드래그 앤 드롭
    var html = "<!DOCTYPE html><html lang=\"ko\"><head>"
    html = html + "<meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">"
    html = html + "<title>FreeLang File Manager</title>"
    html = html + "<style>"
    html = html + "* { margin: 0; padding: 0; box-sizing: border-box; }"
    html = html + "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: linear-gradient(135deg, #667eea, #764ba2); min-height: 100vh; }"
    html = html + ".container { display: flex; height: 100vh; background: white; }"
    html = html + ".sidebar { width: 250px; background: #2c3e50; color: white; padding: 20px; overflow-y: auto; }"
    html = html + ".sidebar h2 { margin-bottom: 20px; font-size: 18px; }"
    html = html + ".sidebar a { display: block; padding: 10px; margin: 5px 0; border-radius: 4px; cursor: pointer; color: white; text-decoration: none; }"
    html = html + ".sidebar a:hover { background: #34495e; }"
    html = html + ".main { flex: 1; display: flex; flex-direction: column; }"
    html = html + ".header { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 20px; display: flex; justify-content: space-between; align-items: center; }"
    html = html + ".header h1 { font-size: 24px; }"
    html = html + ".content { flex: 1; padding: 20px; overflow: auto; }"
    html = html + ".toolbar { display: flex; gap: 10px; margin-bottom: 20px; }"
    html = html + "button { padding: 10px 20px; background: #3498db; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; }"
    html = html + "button:hover { background: #2980b9; }"
    html = html + ".breadcrumb { margin-bottom: 20px; font-size: 14px; }"
    html = html + ".breadcrumb a { color: #3498db; text-decoration: none; cursor: pointer; }"
    html = html + ".breadcrumb a:hover { text-decoration: underline; }"
    html = html + ".drop-zone { border: 2px dashed #3498db; border-radius: 8px; padding: 40px; text-align: center; background: #f8f9fa; cursor: pointer; transition: all 0.3s; margin-bottom: 20px; }"
    html = html + ".drop-zone.dragover { background: #e8f4f8; border-color: #2980b9; }"
    html = html + ".drop-zone p { color: #666; margin: 0; }"
    html = html + ".file-list { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); overflow: hidden; }"
    html = html + ".file-item { display: flex; align-items: center; padding: 12px 15px; border-bottom: 1px solid #eee; cursor: pointer; }"
    html = html + ".file-item:hover { background: #f9f9f9; }"
    html = html + ".file-icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; margin-right: 12px; font-size: 20px; }"
    html = html + ".file-info { flex: 1; }"
    html = html + ".file-name { font-weight: 600; color: #333; }"
    html = html + ".file-meta { font-size: 12px; color: #999; margin-top: 4px; }"
    html = html + ".file-size { width: 100px; text-align: right; color: #999; }"
    html = html + ".file-actions { padding: 0 10px; }"
    html = html + ".file-actions button { padding: 5px 10px; font-size: 12px; margin: 0 3px; }"
    html = html + ".login-form { max-width: 400px; margin: 100px auto; background: white; padding: 40px; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }"
    html = html + ".login-form h1 { text-align: center; margin-bottom: 30px; color: #333; }"
    html = html + ".login-form input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 4px; font-size: 14px; }"
    html = html + ".login-form button { width: 100%; padding: 12px; margin-top: 20px; }"
    html = html + ".progress-bar { width: 100%; height: 20px; background: #eee; border-radius: 10px; overflow: hidden; margin: 10px 0; }"
    html = html + ".progress-fill { height: 100%; background: linear-gradient(90deg, #667eea, #764ba2); transition: width 0.3s; }"
    html = html + "</style>"
    html = html + "</head><body>"
    html = html + "<div class=\"container\" id=\"app\">"
    html = html + "<div class=\"login-form\" id=\"loginForm\">"
    html = html + "<h1>🔐 File Manager</h1>"
    html = html + "<input id=\"username\" placeholder=\"Username\" type=\"text\">"
    html = html + "<input id=\"password\" placeholder=\"Password\" type=\"password\">"
    html = html + "<button onclick=\"login()\">Login</button>"
    html = html + "</div>"
    html = html + "</div>"
    html = html + "<script>"
    html = html + "let authToken = localStorage.getItem('fm_token');"
    html = html + "let currentPath = '/';"
    html = html + "function api(method, url, data) {"
    html = html + "  const opts = { method, headers: { 'Authorization': 'Bearer ' + authToken } };"
    html = html + "  if (data) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(data); }"
    html = html + "  return fetch(url, opts).then(r => r.json());"
    html = html + "}"
    html = html + "function login() {"
    html = html + "  const u = document.getElementById('username').value;"
    html = html + "  const p = document.getElementById('password').value;"
    html = html + "  api('POST', '/api/auth/login', {username: u, password: p}).then(r => {"
    html = html + "    if (r.status === 'ok') { localStorage.setItem('fm_token', r.token); authToken = r.token; showFileManager(); }"
    html = html + "  });"
    html = html + "}"
    html = html + "function showFileManager() {"
    html = html + "  document.getElementById('app').innerHTML = '';"
    html = html + "  const app = document.getElementById('app');"
    html = html + "  app.innerHTML = '<div class=\"sidebar\"><h2>Menu</h2><a onclick=\"navigateTo(\\\"/\\\")\">Home</a><a onclick=\"navigateTo(\\\"/recent\\\")\">Recent</a><a onclick=\"logout()\">Logout</a></div>';"
    html = html + "  app.innerHTML += '<div class=\"main\"><div class=\"header\"><h1>📁 File Manager</h1></div><div class=\"content\"><div class=\"drop-zone\" id=\"dropZone\" ondrop=\"handleDrop(event)\" ondragover=\"handleDragOver(event)\" ondragleave=\"handleDragLeave(event)\"><p>Drag & drop files here or click to upload</p></div><div class=\"file-list\" id=\"fileList\"></div></div></div>';"
    html = html + "  document.getElementById('dropZone').addEventListener('click', () => document.createElement('input').type = 'file');"
    html = html + "  loadFiles();"
    html = html + "}"
    html = html + "function loadFiles() {"
    html = html + "  api('GET', '/api/fs/list?path=' + currentPath).then(r => {"
    html = html + "    if (r.status === 'ok' && r.files) {"
    html = html + "      const list = document.getElementById('fileList');"
    html = html + "      list.innerHTML = '';"
    html = html + "      r.files.forEach(f => {"
    html = html + "        const div = document.createElement('div');"
    html = html + "        div.className = 'file-item';"
    html = html + "        const icon = f.is_dir ? '📂' : '📄';"
    html = html + "        div.innerHTML = `<div class='file-icon'>${icon}</div><div class='file-info'><div class='file-name'>${f.name}</div><div class='file-meta'>${f.size || 0} bytes</div></div><div class='file-size'></div>`;"
    html = html + "        list.appendChild(div);"
    html = html + "      });"
    html = html + "    }"
    html = html + "  });"
    html = html + "}"
    html = html + "function handleDrop(e) {"
    html = html + "  e.preventDefault();"
    html = html + "  document.getElementById('dropZone').classList.remove('dragover');"
    html = html + "  const files = e.dataTransfer.files;"
    html = html + "  for (let f of files) { uploadFile(f); }"
    html = html + "}"
    html = html + "function handleDragOver(e) {"
    html = html + "  e.preventDefault();"
    html = html + "  document.getElementById('dropZone').classList.add('dragover');"
    html = html + "}"
    html = html + "function handleDragLeave(e) {"
    html = html + "  document.getElementById('dropZone').classList.remove('dragover');"
    html = html + "}"
    html = html + "function uploadFile(file) {"
    html = html + "  const fd = new FormData();"
    html = html + "  fd.append('file', file);"
    html = html + "  fd.append('path', currentPath);"
    html = html + "  fetch('/api/upload', { method: 'POST', headers: { 'Authorization': 'Bearer ' + authToken }, body: fd }).then(r => r.json()).then(r => { if (r.status === 'ok') loadFiles(); });"
    html = html + "}"
    html = html + "function navigateTo(path) { currentPath = path; loadFiles(); }"
    html = html + "function logout() { localStorage.removeItem('fm_token'); location.reload(); }"
    html = html + "if (authToken) showFileManager();"
    html = html + "</script>"
    html = html + "</body></html>"

    return html
}

fn main() {
    print("🚀 FreeLang Complete File Manager - Starting on port 13000")
    print("📂 Base directory: " + base_dir)

    rate_limiter = create_rate_limiter()
    db = init_users_db()

    print("✅ Default user: admin / admin")
    print("✅ Features: Core Ops, Users, Search, Preview, Upload, Share, Shell, HTTPS")
    print("✅ Open http://localhost:13000/ in browser")
    print("")

    vm.http.startServer(13000, fn(method: String, path: String, headers: Map, body: String) -> String {
        var remote_ip = map_get(headers, "X-Forwarded-For") ?? "127.0.0.1"

        if !check_rate_limit(rate_limiter, remote_ip) {
            return "{\"status\":\"error\",\"error\":\"Rate limit exceeded\"}"
        }

        if path == "/" || path == "/login.html" {
            return generate_full_html_ui()
        }

        if str_startswith(path, "/api/") {
            return handle_api_request(method, path, headers, body)
        }

        return "{\"status\":\"error\",\"error\":\"Not found\"}"
    })
}

main()
