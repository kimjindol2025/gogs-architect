}

fn handle_preview_api(path: String, headers: Map) -> String {
    // 미리보기: 텍스트, 이미지, 비디오, 오디오, Office 문서
    var auth = map_get(headers, "Authorization")
    if auth == null { return "{\"status\":\"error\"}" }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)
    var user_id = map_get(session, "user_id")

    if !map_get(session, "valid") {
        return "{\"status\":\"error\"}"
    }

    var full_path = base_dir + path
    var filename = str_substring(path, str_rfind(path, "/") + 1, str_len(path))

    var response = map_new()

    if is_text_file(filename) {
        var content = read_file_text(full_path)
        map_set(response, "type", "text")
        map_set(response, "content", sanitize_html(content))
    } else if is_media_file(filename) {
        map_set(response, "type", "media")
        map_set(response, "mime", get_mime_type(filename))
    } else if is_office_file(filename) {
        map_set(response, "type", "office")
    } else {
        map_set(response, "type", "binary")
    }

    map_set(response, "status", "ok")
    return json_encode_simple(response)
}

fn handle_search_api(params: Map, headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null { return "{\"status\":\"error\"}" }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)

    if !map_get(session, "valid") {
        return "{\"status\":\"error\"}"
    }

    var query = map_get(params, "q") ?? ""
    var file_type = map_get(params, "type") ?? ""

    var filters = map_new()
    map_set(filters, "type", file_type)
    map_set(filters, "min_size", 0)
    map_set(filters, "max_size", 2147483647)

    var results = search_files(query, base_dir, filters)

    var response = map_new()
    map_set(response, "status", "ok")
    map_set(response, "query", query)
    map_set(response, "results", results)

    return json_encode_simple(response)
}

