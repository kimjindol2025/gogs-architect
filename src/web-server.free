// web-server.free - Complete File Manager HTTP Server (Port 13000)
// Features: Core Ops, User Management, Smart Search, Preview, HTTPS, Shell, Share

var rate_limiter = null
var db = null
var base_dir = "/home"
var ssl_config = null

fn parse_query_string(query_str: String) -> Map {
    // 쿼리 문자열 파싱
    var params = map_new()

    if query_str == null || str_len(query_str) == 0 {
        return params
    }

    var pairs = str_split(query_str, "&")
    var i = 0
    while i < list_len(pairs) {
        var pair = list_get(pairs, i)
        var key_value = str_split(pair, "=")
        if list_len(key_value) == 2 {
            var key = list_get(key_value, 0)
            var value = list_get(key_value, 1)
            map_set(params, key, url_decode(value))
        }
        i = i + 1
    }

    return params
}

fn url_decode(encoded: String) -> String {
    // URL 디코딩
    var result = ""
    var i = 0
    while i < str_len(encoded) {
        var char = str_substring(encoded, i, i + 1)
        if char == "+" {
            result = result + " "
        } else if char == "%" && i + 2 < str_len(encoded) {
            var hex = str_substring(encoded, i + 1, i + 3)
            // 간단한 구현 (모든 % 인코딩을 지원하지는 않음)
            result = result + char
            i = i + 2
        } else {
            result = result + char
        }
        i = i + 1
    }
    return result
}

fn handle_api_request(method: String, path: String, headers: Map, body: String) -> String {
    // API 라우팅

    // 인증
    if path == "/api/auth/login" && method == "POST" {
        return handle_login_api(body)
    }

    if path == "/api/auth/logout" && method == "POST" {
        return handle_logout_api(headers)
    }

    if path == "/api/auth/me" && method == "GET" {
        return handle_me_api(headers)
    }

    // 파일시스템
    if str_startswith(path, "/api/fs/list") && method == "GET" {
        var query_idx = str_find(path, "?")
        var query = ""
        if query_idx >= 0 {
            query = str_substring(path, query_idx + 1, str_len(path))
        }
        var params = parse_query_string(query)
        var p = map_get(params, "path") ?? "/"
        return handle_list_api(p, headers)
    }

    if path == "/api/fs/mkdir" && method == "POST" {
        return handle_mkdir_api(body, headers)
    }

    if path == "/api/fs/delete" && method == "POST" {
        return handle_delete_api(body, headers)
    }

    if path == "/api/fs/rename" && method == "POST" {
        return handle_rename_api(body, headers)
    }

    if path == "/api/fs/copy" && method == "POST" {
        return handle_copy_api(body, headers)
    }

    if path == "/api/fs/move" && method == "POST" {
        return handle_move_api(body, headers)
    }

    // 파일 작업
    if str_startswith(path, "/api/file/read") && method == "GET" {
        var query_idx = str_find(path, "?")
        var query = ""
        if query_idx >= 0 {
            query = str_substring(path, query_idx + 1, str_len(path))
        }
        var params = parse_query_string(query)
        var p = map_get(params, "path") ?? "/"
        return handle_read_api(p, headers)
    }

    if path == "/api/file/write" && method == "POST" {
        return handle_write_api(body, headers)
    }

    if path == "/api/file/preview" && method == "GET" {
        var query_idx = str_find(path, "?")
        var query = ""
        if query_idx >= 0 {
            query = str_substring(path, query_idx + 1, str_len(path))
        }
        var params = parse_query_string(query)
        var p = map_get(params, "path") ?? "/"
        return handle_preview_api(p, headers)
    }

    // 검색
    if str_startswith(path, "/api/search") && method == "GET" {
        var query_idx = str_find(path, "?")
        var query = ""
        if query_idx >= 0 {
            query = str_substring(path, query_idx + 1, str_len(path))
        }
        var params = parse_query_string(query)
        return handle_search_api(params, headers)
    }

    // 업로드/다운로드
    if path == "/api/upload" && method == "POST" {
        return handle_upload_api(body, headers)
    }

    if str_startswith(path, "/api/download") && method == "GET" {
        var query_idx = str_find(path, "?")
        var query = ""
        if query_idx >= 0 {
            query = str_substring(path, query_idx + 1, str_len(path))
        }
        var params = parse_query_string(query)
        var p = map_get(params, "path") ?? "/"
        return handle_download_api(p, headers)
    }

    // 공유
    if str_startswith(path, "/api/share/create") && method == "POST" {
        return handle_share_create_api(body, headers)
    }

    if str_startswith(path, "/api/share/delete") && method == "POST" {
        var token = str_substring(path, str_rfind(path, "/") + 1, str_len(path))
        return handle_share_delete_api(token, headers)
    }

    if str_startswith(path, "/api/share/list") && method == "GET" {
        return handle_share_list_api(headers)
    }

    // 셸
    if path == "/api/shell/run" && method == "POST" {
        return handle_shell_api(body, headers)
    }

    // 관리자
    if path == "/api/admin/users" && method == "GET" {
        return handle_list_users_api(headers)
    }

    if path == "/api/admin/users" && method == "POST" {
        return handle_create_user_api(body, headers)
    }

    return "{\"status\":\"error\",\"error\":\"Not found\"}"
}

// ====== API 핸들러들 ======

fn handle_login_api(body: String) -> String {
    var data = parse_json_simple(body)
    var username = map_get(data, "username")
    var password = map_get(data, "password")

    var login_result = user_login(db, username, password)

    if map_get(login_result, "success") {
        var response = map_new()
        map_set(response, "status", "ok")
        map_set(response, "token", map_get(login_result, "token"))
        return json_encode_simple(response)
    } else {
        var response = map_new()
        map_set(response, "status", "error")
        map_set(response, "error", map_get(login_result, "error"))
        return json_encode_simple(response)
    }
}

fn handle_logout_api(headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth != null {
        var token = str_substring(auth, 7, str_len(auth))
        user_logout(db, token)
    }

    var response = map_new()
    map_set(response, "status", "ok")
    return json_encode_simple(response)
}

fn handle_me_api(headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null {
        return "{\"status\":\"error\",\"error\":\"Unauthorized\"}"
    }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)

    if !map_get(session, "valid") {
        return "{\"status\":\"error\",\"error\":\"Invalid session\"}"
    }

    var user_id = map_get(session, "user_id")
    var user = get_user(db, user_id)

    var response = map_new()
    map_set(response, "status", "ok")
    map_set(response, "user", map_new())

    return json_encode_simple(response)
}

fn handle_list_api(path: String, headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null {
        return "{\"status\":\"error\"}"
    }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)

    if !map_get(session, "valid") {
        return "{\"status\":\"error\"}"
    }

    var user_id = map_get(session, "user_id")
    if !check_permission(db, user_id, "read") {
        return "{\"status\":\"error\",\"error\":\"Permission denied\"}"
    }

    if !validate_path(path, base_dir) {
        return "{\"status\":\"error\",\"error\":\"Invalid path\"}"
    }

    var full_path = base_dir + path
    var files = list_directory(full_path)

    var response = map_new()
    map_set(response, "status", "ok")
    map_set(response, "files", files)

    return json_encode_simple(response)
}

fn handle_mkdir_api(body: String, headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null {
        return "{\"status\":\"error\"}"
    }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)
    var user_id = map_get(session, "user_id")

    if !map_get(session, "valid") || !check_permission(db, user_id, "write") {
        return "{\"status\":\"error\"}"
    }

    var data = parse_json_simple(body)
    var path = map_get(data, "path")
    var name = sanitize_filename(map_get(data, "name"))

    if !validate_path(path, base_dir) {
        return "{\"status\":\"error\"}"
    }

    var full_path = base_dir + path + "/" + name
    var success = create_directory(full_path)

    audit_log(db, user_id, "fs_mkdir", path, success)

    var response = map_new()
    map_set(response, "status", success ? "ok" : "error")
    return json_encode_simple(response)
}

fn handle_delete_api(body: String, headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null {
        return "{\"status\":\"error\"}"
    }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)
    var user_id = map_get(session, "user_id")

    if !map_get(session, "valid") || !check_permission(db, user_id, "delete") {
        return "{\"status\":\"error\"}"
    }

    var data = parse_json_simple(body)
    var path = map_get(data, "path")

    if !validate_path(path, base_dir) {
        return "{\"status\":\"error\"}"
    }

    var full_path = base_dir + path
    var success = false

    if file_is_dir(full_path) {
        success = delete_directory_recursive(full_path)
    } else {
        success = delete_file(full_path)
    }

    audit_log(db, user_id, "fs_delete", path, success)

    var response = map_new()
    map_set(response, "status", success ? "ok" : "error")
    return json_encode_simple(response)
}

fn handle_rename_api(body: String, headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null { return "{\"status\":\"error\"}" }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)
    var user_id = map_get(session, "user_id")

    if !map_get(session, "valid") || !check_permission(db, user_id, "write") {
        return "{\"status\":\"error\"}"
    }

    var data = parse_json_simple(body)
    var old_path = map_get(data, "old_path")
    var new_name = sanitize_filename(map_get(data, "new_name"))

    if !validate_path(old_path, base_dir) {
        return "{\"status\":\"error\"}"
    }

    var full_old = base_dir + old_path
    var dirname = str_substring(old_path, 0, str_rfind(old_path, "/"))
    var full_new = base_dir + dirname + "/" + new_name

    var success = rename_file(full_old, full_new)

    audit_log(db, user_id, "fs_rename", old_path, success)

    var response = map_new()
    map_set(response, "status", success ? "ok" : "error")
    return json_encode_simple(response)
}

fn handle_copy_api(body: String, headers: Map) -> String {
    var auth = map_get(headers, "Authorization")
    if auth == null { return "{\"status\":\"error\"}" }

    var token = str_substring(auth, 7, str_len(auth))
    var session = verify_session(db, token)
    var user_id = map_get(session, "user_id")

    if !map_get(session, "valid") || !check_permission(db, user_id, "write") {
        return "{\"status\":\"error\"}"
    }

    var data = parse_json_simple(body)
    var src = map_get(data, "src")
    var dest = map_get(data, "dest")

    var success = false
    var full_src = base_dir + src
    var full_dest = base_dir + dest

    if file_is_dir(full_src) {
        success = copy_directory_recursive(full_src, full_dest)
    } else {
        success = copy_file(full_src, full_dest)
    }

    audit_log(db, user_id, "fs_copy", src, success)

    var response = map_new()
    map_set(response, "status", success ? "ok" : "error")
    return json_encode_simple(response)
}

