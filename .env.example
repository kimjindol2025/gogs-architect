# GOGS Architect - 환경 변수 설정
# .env 파일을 만들어 실제 값을 설정하세요

# ============================================
# API 서버
# ============================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ============================================
# GOGS 서버 설정
# ============================================
GOGS_BASE_URL=https://gogs.dclub.kr
GOGS_API_TOKEN=your_gogs_api_token_here
GOGS_USERNAME=kim
GOGS_WEBHOOK_URL=https://architect.gogs.dclub.kr/api/v1/webhook/gogs

# ============================================
# 데이터베이스 (선택사항)
# ============================================
DB_TYPE=json
# DB_TYPE=sqlite
# SQLITE_DB_PATH=./data/architect.db

# ============================================
# 모니터링 및 알림
# ============================================
MONITORING_ENABLED=true
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_RESPONSE_TIME_THRESHOLD=1000
ALERT_MEMORY_THRESHOLD=0.8
ALERT_WEBHOOK_FAILURE_THRESHOLD=0.1

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 보안
# ============================================
CORS_ENABLED=true
CORS_ORIGINS=*
INPUT_VALIDATION_ENABLED=true
SQL_INJECTION_CHECK=true
XSS_CHECK=true

# ============================================
# 캐싱
# ============================================
CACHE_ENABLED=true
CACHE_TTL=3600000

# ============================================
# 파일 경로
# ============================================
DATA_DIR=./data
LOGS_DIR=./logs
CACHE_DIR=./cache

# ============================================
# 클라우드 (선택사항)
# ============================================
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================
# 슬랙 알림 (선택사항)
# ============================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SLACK_ENABLED=false

# ============================================
# 이메일 알림 (선택사항)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=architect@gogs.dclub.kr
# EMAIL_ALERTS_ENABLED=false

# ============================================
# 개발 전용
# ============================================
# DEBUG=true
# MOCK_GOGS=false
