{
  "name": "gogs-architect",
  "version": "0.1.0",
  "description": "Gogs AI 아키텍트 시스템 - 277개 Gogs 저장소를 AI 지식 베이스로 변환",
  "main": "src/cli.js",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node src/api-server-v3.js",
    "dev": "NODE_ENV=development node src/api-server-v3.js",
    "test": "node tests/test-gogs-client.js",
    "test:webhook": "node src/test-webhook-manager.js",
    "test:monitoring": "node src/test-monitoring-system.js",
    "deploy": "bash deploy.sh production",
    "deploy:staging": "bash deploy.sh staging",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop gogs-architect-api",
    "pm2:restart": "pm2 restart gogs-architect-api",
    "pm2:logs": "pm2 logs gogs-architect-api",
    "gogs:setup": "node scripts/setup-gogs-webhooks.js",
    "lint": "eslint src/ --fix",
    "docs": "echo '📖 API 문서는 http://localhost:3000/ 을 참고하세요'"
  },
  "keywords": ["gogs", "ai", "knowledge-base", "architect"],
  "author": "Claude Code",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
