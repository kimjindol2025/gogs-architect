      "id": "test/function/test.py:0:tokenize",
      "type": "function",
      "name": "tokenize",
      "content": "def tokenize(text):\n    \"\"\"문자열을 토큰으로 분해\"\"\"\n    tokens = []\n    for char in text:\n        if char == ' ':\n            tokens.append(char)\n    return tokens\n",
      "meta": {
        "repo": "test",
        "file": "test.py",
        "lineStart": 1,
        "lineEnd": 8,
        "language": "python"
      }
    },
    {
      "id": "test/function/test.py:8:analyze",
      "type": "function",
      "name": "analyze",
      "content": "def analyze(text):\n    \"\"\"텍스트 분석\"\"\"\n    tokens = tokenize(text)\n    return len(tokens)",
