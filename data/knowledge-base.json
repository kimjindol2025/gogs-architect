    {
      "id": "test/js/range.js:0:range",
      "type": "function",
      "name": "range",
      "content": "function range(start, end) {\n  // 범위 검증 부재 (ADR-001 위반)\n  const arr = [];\n  for (let i = start; i <= end; i++) {\n    arr.push(i);\n  }\n  return arr;\n}\n",
      "meta": {
        "repo": "test",
        "file": "range.js",
        "lineStart": 1,
        "lineEnd": 9,
        "language": "javascript"
      }
    },
    {
      "id": "test/js/range.js:8:rangeFixed",
      "type": "function",
      "name": "rangeFixed",
      "content": "\nfunction rangeFixed(start, end) {\n  // ADR-001 준수: 범위 검증 추가\n  if (start < 0 || end > 1000000) {\n    throw new Error('Range out of bounds');\n  }\n  const arr = [];\n  for (let i = start; i <= end; i++) {\n    arr.push(i);\n  }\n  return arr;\n}",
      "meta": {
        "repo": "test",
        "file": "range.js",
        "lineStart": 9,
        "lineEnd": 20,
        "language": "javascript"
      }
